# Config del micro de ingesta. Copiá a .env para correr local.
# El micro NO toca la DB: NO pongas acá la service_role key ni credenciales de Postgres.

# Auth: validación del JWT de Supabase.
#  - Opción A (recomendada / moderna): solo SUPABASE_URL → valida vía JWKS (RS256/ES256).
#  - Opción B (legacy): SUPABASE_JWT_SECRET (Settings → API → JWT secret) → valida HS256.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
JWT_AUDIENCE=authenticated

# Origen(es) de la web para CORS (coma-separados).
WEB_ORIGIN=http://localhost:5173

# Endurecimiento contra input no confiable.
MAX_UPLOAD_BYTES=10485760
PROCESS_TIMEOUT_SECONDS=30

# --- Fallback LLM/visión (Fase B, F2-12) ---
# Si la Fase A (OCR + regex) queda floja, se manda la imagen a un modelo de visión.
# DESACTIVADO si GEMINI_API_KEY está vacío → el micro usa solo la Fase A (no rompe).
# Gemini es free y sin tarjeta: creá la key en https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Confianza de la Fase A por debajo de la cual se intenta el fallback (si hay key).
LLM_FALLBACK_MAX_CONFIDENCE=0.5
